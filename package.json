{
  "name": "smartlocal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "description": "Smart Local Services Finder & Emergency Assistance System",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "pnpm --filter smartlocal-backend dev",
    "dev:frontend": "pnpm --filter smartlocal-frontend dev",
    "dev:backend": "pnpm --filter smartlocal-backend dev",
    "start": "pnpm --filter smartlocal-backend start",
    "build": "pnpm --filter smartlocal-frontend build"
  },
  "engines": {
    "node": ">=20"
  }
}
